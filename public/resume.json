        {
            "name": "AI-Powered Smart Calendar",
            "stack": [
                "Java",
                "LangChain4j",
                "OpenAI",
                "Google Calendar API"
            ],
            "summary": "Natural-language scheduling assistant that optimizes event planning end-to-end.",
            "githubUrl": "https://github.com/D3nizG/Calistant",
            "playUrl": "",
            "metrics": [
                "Processed 10 000+ scheduling requests with 94 % intent-recognition accuracy",
                "Creates or updates events in <2s,cutting manual setup time by 50 %",
                "Serves 200+ active users with 99.5 % uptime"
            ],
            "longDescription": "Scheduling between multiple people and shifting priorities can be a major time sink. This Java-based microservice wraps OpenAI's LLMs via LangChain4j into a conversational API that interprets plain-English requests - e.g. “Find me a 30-minute slot tomorrow afternoon with Alice and Bob” - and handles availability checks, conflict resolution, and time-zone conversions in under two seconds. With seamless Google Calendar integration and a Spring Boot deployment, it cut manual scheduling overhead by 50% in beta tests while serving 200+ users at 99.5% uptime."
        },
        {
            "name": "Sennet",
            "stack": [
                "React",
                "Vite",
                "Express",
                "Socket.IO",
                "Prisma"
            ],
            "summary": "Multiplayer Senet platform with matchmaking, private lobbies, AI, and persistent player profiles.",
            "githubUrl": "https://github.com/D3nizG/sennet",
            "playUrl": "https://sennet.d3nizg.dev",
            "metrics": [
                "Server-authoritative gameplay with realtime turns over Socket.IO",
                "Online matchmaking, private friend lobbies, and reconnection support",
                "Single-player AI, player stats, and shared game-engine logic across client and server"
            ],
            "longDescription": "Sennet is a production-ready web implementation of the ancient Egyptian board game Senet. It is built as a monorepo with a shared TypeScript game engine, a React + Vite client, and an Express + Socket.IO backend backed by Prisma. The stack supports online matchmaking, private friend matches, single-player AI, persistent player profiles, and a server-authoritative rules engine so rolls, moves, and game state stay trustworthy across reconnects and multiplayer sessions."
        },
        {
